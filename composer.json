{
    "name": "am2tec/laravel-brazilian-ceps",
    "description": "A package for querying zip codes for Brazilian addresses.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "brazil",
        "ceps",
        "correios"
    ],
    "authors": [
        {
            "name": "am2tec",
            "email": "albertomorais80@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1 <9.0",
        "ext-json": "*",
        "ext-fileinfo": "*",
        "ext-mbstring": "*",
        "illuminate/support": "^9 || ^10 || ^11 || ^12 || ^13",
        "illuminate/http": "^9 || ^10 || ^11 || ^12 || ^13",
        "guzzlehttp/guzzle": "^7"
    },
    "autoload": {
        "psr-4": {
            "Am2Tec\\LaravelBrazilianCeps\\": "./src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Am2Tec\\LaravelBrazilianCeps\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/testbench package:test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Am2Tec\\LaravelBrazilianCeps\\LaravelBrazilianCepsServiceProvider"
            ]
        }
    },
    "suggest": {
        "am2tec/laravel-a1-pdf-sign": "Sign PDF files with valid x509 certificates."
    },
    "require-dev": {
        "orchestra/testbench": "^7 || ^8 || ^9 || ^10",
        "nunomaduro/collision": "^6 || ^7 || ^8"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
